# 复制为本目录下的 .env 并填写。仅由 Node 读取（不提交、不发给浏览器）。

PORT=3000

# 后台与同步写操作共用唯一密钥（管理页、POST /api/photo-timeline/sync 等）。
# 请求头：Authorization: Bearer <密钥>，或 X-Photo-Timeline-Sync-Secret。
# ADMIN_SECRET=请改为随机长字符串

# 照片时间轴：高德开放平台 Web 服务 Key（逆地理用；高德失败可配 OSM 兜底）
# https://lbs.amap.com/api/webservice/create-project-and-key
# AMAP_WEB_KEY=你的Web服务Key

# 地图页：高德地图 JS API Key（未配置时会回退到 AMAP_WEB_KEY）
# AMAP_JS_KEY=你的JSAPI Key

# 可选：高德地图安全密钥（若你的 JS API 配置启用了安全密钥）
# AMAP_SECURITY_JS_CODE=你的安全密钥

# 可选：当高德逆地理失败时，允许使用公开 OSM/Nominatim 做兜底（注意其使用政策与限流）
# OSM_NOMINATIM_FALLBACK=1

# 可选：给 OSM/Nominatim 请求带上自定义 User-Agent
# PHOTO_TIMELINE_HTTP_USER_AGENT=photo-album/1.0 (+your-contact)

# 可选：写回调试日志；默认 server/.data/photo-timeline-write.log
# PHOTO_TIMELINE_WRITE_LOG=/tmp/photo-timeline-write.log

# 可选：照片素材库目录（用于扫描 photo-timeline-entry.json + 提供 /assets/live 静态访问）
# - 默认：public/assets/live
# - 允许绝对路径：/Volumes/Photos/live
# - 允许相对路径（相对 photo-album 根目录）：../my-photo-library/live
# PHOTO_TIMELINE_LIVE_ROOT=public/assets/live

